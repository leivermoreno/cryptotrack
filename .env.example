COINGECKO_KEY=YOUR COINGECKO API KEY HERE
DATABASE_URI=YOUR DATABASE URI HERE
# Development toggle. true enables DEBUG (dev defaults for SECRET_KEY/hosts/CSRF).
# Unset or false = production posture (those vars become required). Fail-closed.
DJANGO_DEBUG=true
# Required in production; in development a built-in insecure fallback is used if unset.
SECRET_KEY=YOUR DJANGO SECRET KEY HERE
# Required in production; in development defaults to localhost origins if unset.
CSRF_TRUSTED_ORIGINS=https://your-domain.example
ALLOWED_HOSTS=your-domain.example,www.your-domain.example

# --- Production security (optional) ---
# These apply only when DEBUG is off (DJANGO_DEBUG unset/false) and all have safe
# defaults, so they can be left unset. See README "Environment" for details.
#
# Railway/PaaS deploys MUST set this to true: TLS terminates at the platform
# edge, so Django learns the real scheme from X-Forwarded-Proto. Leaving it
# unset behind a TLS-terminating proxy makes SECURE_SSL_REDIRECT loop forever.
TRUST_PROXY_SSL_HEADER=true
# Redirect HTTP -> HTTPS. Defaults to true in production; set false only as an
# incident kill-switch (e.g. to break a redirect loop while debugging proxy).
SECURE_SSL_REDIRECT=true
# HSTS max-age in seconds. Start conservative (3600 = 1h) and ramp up once
# HTTPS is proven stable (target 31536000 = 1 year). Defaults to 3600.
SECURE_HSTS_SECONDS=3600
# Keep both off until HSTS has run at a long max-age with zero HTTPS incidents;
# preload is effectively irreversible. Default false.
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
