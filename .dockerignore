# Keep the build context (and the prod image's `COPY . .`) minimal and clean.
.git
.github
.gitignore

# Virtualenvs — deps are installed fresh inside the image.
venv/
env/

# Python caches / build artifacts.
__pycache__/
*.py[cod]
.ruff_cache/

# Collected static is regenerated by collectstatic during the prod build;
# never ship a stale copy.
staticfiles/

# Secrets and local-only config never belong in an image layer.
.env

# Docker + editor + agent scaffolding not needed at build time.
Dockerfile
.dockerignore
docker-compose*.yml
.idea/
.agents/
.codex/
inspection/
